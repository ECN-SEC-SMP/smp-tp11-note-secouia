# =============================================================================
# .gitignore – Les Aventuriers du Rail
# =============================================================================

# ── Dossiers de build CMake ───────────────────────────────────────────────────
build/
build-*/
cmake-build-*/
out/

# ── Documentation générée ────────────────────────────────────────────────────
docs/html/
docs/latex/
docs/xml/
docs/man/

# ── Binaires et bibliothèques ────────────────────────────────────────────────
*.exe
*.out
*.app
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib

# ── Fichiers objets et temporaires du compilateur ────────────────────────────
*.o
*.obj
*.pch
*.gch
*.pdb
*.ilk
*.exp
*.map
*.d

# ── CMake (fichiers générés) ──────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
Testing/

# ── CTest ────────────────────────────────────────────────────────────────────
LastTest.log
CTestCostData.txt

# ── IDEs ──────────────────────────────────────────────────────────────────────

# CLion / JetBrains
.idea/
*.iml
cmake-build-debug/
cmake-build-release/

# Visual Studio
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.VC.db
*.VC.opendb

# VS Code
.vscode/*
!.vscode/c_cpp_properties.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
*.code-workspace

# Xcode
*.xcodeproj/
*.xcworkspace/
DerivedData/

# Qt Creator
*.pro.user
*.qbs.user

# ── Systèmes de fichiers ──────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ── Couverture de code ────────────────────────────────────────────────────────
*.gcno
*.gcda
*.gcov
coverage.info
coverage/

# ── Sanitizers / profiling ────────────────────────────────────────────────────
*.profdata
*.profraw
callgrind.out.*
massif.out.*
vgcore.*

# ── Packages / vcpkg ─────────────────────────────────────────────────────────
vcpkg_installed/

CLAUDE.md
.claude
build
*.log
*.out
*.toc
*.aux
CR/_minted-rapport_new/
*.gz
.claude/build/
